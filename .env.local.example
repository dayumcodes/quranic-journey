# ── OAuth PKCE (browser) ───────────────────────────────────────────────────────
NEXT_PUBLIC_OAUTH_CLIENT_ID=
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Quran Foundation Content API (server only — NEVER use NEXT_PUBLIC_ here) ─
# Credentials from Request Access email: same Client ID + Client Secret pair you
# use for client_credentials tokens. Separate from NEXT_PUBLIC_* login app id only
# when Quran Foundation issues different apps; typically use the Content pair here.
QF_ENV=prelive
QF_CLIENT_ID=
QF_CLIENT_SECRET=

# Optional overrides (defaults follow QF_ENV):
# QF_AUTH_BASE_URL=https://prelive-oauth2.quran.foundation
# QF_API_BASE_URL=https://apis-prelive.quran.foundation

# prelive:  auth https://prelive-oauth2.quran.foundation  |  API https://apis-prelive.quran.foundation
# production:  auth https://oauth2.quran.foundation  |  API https://apis.quran.foundation
